---
import Base from "../layouts/Base.astro";

---

<Base title="ページが見つかりません" description="お探しのページは存在しないか、移動した可能性があります。">
  <section class="not-found">
    <div class="container">
      <p class="code">404</p>
      <h1>ページが見つかりません</h1>
      <p class="message">お探しのページは存在しないか、移動した可能性があります。</p>
      <a href="/" class="btn-home">トップページへ戻る</a>
    </div>
  </section>
</Base>

<style>
  .not-found {
    text-align: center;
    padding: 8rem var(--container-px);
  }

  .code {
    font-size: 6rem;
    font-weight: 700;
    color: var(--color-border);
    margin: 0 0 0.25em;
    line-height: 1;
  }

  h1 { font-size: 1.75rem; margin-bottom: 0.75rem; }

  .message {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .btn-home {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius);
    background: var(--color-primary);
    color: var(--color-primary-fg);
    font-weight: 600;
    transition: background 0.15s;
  }

  .btn-home:hover { background: var(--color-primary-hover); }
</style>
