---
import { getEmDashEntry } from "emdash";
import Base from "../layouts/Base.astro";
import MarketingBlocks from "../components/MarketingBlocks.astro";

const page = await getEmDashEntry("pages", "pricing");
---

<Base
  title={page?.data.seoTitle ?? "料金プラン"}
  description={page?.data.seoDescription ?? undefined}
>
  {page ? (
    <MarketingBlocks blocks={page.data.content} />
  ) : (
    <div class="empty-state">
      <h1>料金プラン</h1>
      <p>管理画面でコンテンツを編集してください。</p>
      <a href="/_emdash/admin">管理画面を開く →</a>
    </div>
  )}
</Base>

<style>
  .empty-state {
    text-align: center;
    padding: 6rem var(--container-px);
    max-width: 480px;
    margin: 0 auto;
  }
  .empty-state p { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .empty-state a { color: var(--color-primary); font-weight: 600; }
</style>
