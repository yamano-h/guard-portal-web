---
import { getEmDashCollection, getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const { entries: posts } = await getEmDashCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const { entry: post } = await getEmDashEntry("posts", slug);

if (!post) {
  return Astro.redirect("/404");
}

function formatDate(dateStr: string) {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return d.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" });
}
---

<Base
  title={post.data.seo_title ?? post.data.title}
  description={post.data.seo_description ?? post.data.excerpt ?? undefined}
>
  <article>
    <!-- Post header -->
    <header class="post-header">
      <div class="container">
        <div class="post-header-inner">
          <a href="/blog" class="back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            ブログ一覧
          </a>
          <div class="post-meta">
            {post.data.category && (
              <span class="badge">{post.data.category}</span>
            )}
            {post.data.post_date && (
              <time datetime={post.data.post_date} class="date">
                {formatDate(post.data.post_date)}
              </time>
            )}
          </div>
          <h1>{post.data.title}</h1>
        </div>
      </div>
    </header>

    <!-- Post body -->
    <div class="post-body">
      <div class="container">
        <div class="prose">
          {post.data.content && (
            <PortableText value={post.data.content} />
          )}
        </div>

        <!-- CTA -->
        <div class="post-cta">
          <div class="cta-content">
            <div class="cta-icon" aria-hidden="true">🛡</div>
            <div>
              <p class="cta-title">書類管理を効率化しませんか？</p>
              <p class="cta-desc">ガードポータルで警備業の法定書類をクラウド管理。30日間無料でお試しいただけます。</p>
            </div>
          </div>
          <div class="cta-actions">
            <a href="/contact" class="cta-btn-primary">無料トライアルを始める →</a>
            <a href="/" class="cta-btn-secondary">詳細を見る</a>
          </div>
        </div>

        <div class="post-nav">
          <a href="/blog" class="back-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            ブログ一覧に戻る
          </a>
        </div>
      </div>
    </div>
  </article>
</Base>

<style>
  /* === Post Header === */
  .post-header {
    padding: 3.5rem 0 2.5rem;
    background: linear-gradient(160deg, #F8FAFC 0%, #EFF6FF 60%, #F8FAFC 100%);
    border-bottom: 1px solid #E2E8F0;
  }

  .post-header-inner {
    max-width: 720px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #64748B;
    margin-bottom: 1.25rem;
    transition: color 150ms;
  }

  .back-link:hover { color: #2563EB; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  /* Badge — DESIGN.md バッジスタイル */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    background: #EFF6FF;
    color: #1D4ED8;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid #BFDBFE;
  }

  .date {
    font-size: 0.75rem;
    color: #94A3B8;
    font-weight: 500;
  }

  .post-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 800;
    color: #0F172A;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0;
  }

  /* === Post Body === */
  .post-body {
    background: #F8FAFC;
    padding: 3.5rem 0 6rem;
  }

  /* Prose — 記事本文のタイポグラフィ */
  .prose {
    max-width: 720px;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: #0F172A;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    color: #0F172A;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #E2E8F0;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0F172A;
    letter-spacing: -0.01em;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
    color: #334155;
    line-height: 1.8;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
    color: #334155;
  }

  .prose :global(a) {
    color: #2563EB;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(strong) {
    color: #0F172A;
    font-weight: 600;
  }

  /* === CTA Card — testimonial-card スタイルに合わせる === */
  .post-cta {
    max-width: 720px;
    margin: 3.5rem 0 0;
    background: #0F172A;
    border: 1px solid #1E293B;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cta-content {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .cta-icon {
    font-size: 2rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .cta-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #F1F5F9;
    margin: 0 0 0.4rem;
    line-height: 1.4;
  }

  .cta-desc {
    font-size: 0.875rem;
    color: #94A3B8;
    line-height: 1.65;
    margin: 0;
  }

  .cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
    border-top: 1px solid #1E293B;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    background: #2563EB;
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    box-shadow: 0 1px 3px rgba(37, 99, 235, 0.3);
    transition: background 150ms;
  }

  .cta-btn-primary:hover { background: #1D4ED8; }

  .cta-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.25rem;
    background: transparent;
    color: #94A3B8;
    border: 1px solid #334155;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    transition: border-color 150ms, color 150ms;
  }

  .cta-btn-secondary:hover {
    color: #CBD5E1;
    border-color: #475569;
  }

  /* === Post Nav === */
  .post-nav {
    max-width: 720px;
    margin: 2rem 0 0;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748B;
    transition: color 150ms;
  }

  .back-btn:hover { color: #2563EB; }

  /* === Responsive === */
  @media (max-width: 768px) {
    .post-header { padding: 2.5rem 0 2rem; }
    .post-body { padding: 2.5rem 0 4rem; }
    .post-cta { padding: 1.5rem; gap: 1.25rem; }
    .cta-content { flex-direction: column; gap: 0.75rem; }
    .cta-icon { font-size: 1.5rem; }
    .prose :global(h2) { font-size: 1.2rem; }
    .prose :global(h3) { font-size: 1rem; }
  }
</style>
