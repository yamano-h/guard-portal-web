---
import { PortableText } from "emdash/components";

interface Props {
  blocks: any[];
}

const { blocks = [] } = Astro.props;
---

{blocks.map((block) => {
  switch (block._type) {
    case "marketing.hero":
      return (
        <section class="hero">
          <div class="container">
            <h1 set:html={block.headline?.replace(/\n/g, "<br>")} />
            {block.subheadline && <p class="hero-sub">{block.subheadline}</p>}
            {(block.primaryCta || block.secondaryCta) && (
              <div class="hero-ctas">
                {block.primaryCta && (
                  <a href={block.primaryCta.url} class="cta-primary">{block.primaryCta.label}</a>
                )}
                {block.secondaryCta && (
                  <a href={block.secondaryCta.url} class="cta-secondary">{block.secondaryCta.label}</a>
                )}
              </div>
            )}
          </div>
        </section>
      );

    case "marketing.features":
      return (
        <section class="features" id="features">
          <div class="container">
            <div class="section-header">
              <h2>{block.headline}</h2>
              {block.subheadline && <p>{block.subheadline}</p>}
            </div>
            <div class="features-grid">
              {(block.items ?? []).map((item: any) => (
                <div class="feature-card">
                  <div class="feature-icon" aria-hidden="true">✦</div>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      );

    case "marketing.testimonials":
      return (
        <section class="testimonials">
          <div class="container">
            <div class="section-header">
              <h2>{block.headline}</h2>
            </div>
            <div class="testimonials-grid">
              {(block.items ?? []).map((item: any) => (
                <blockquote class="testimonial-card">
                  <p class="quote">"{item.quote}"</p>
                  <footer>
                    <strong>{item.author}</strong>
                    <span>{item.role}、{item.company}</span>
                  </footer>
                </blockquote>
              ))}
            </div>
          </div>
        </section>
      );

    case "marketing.pricing":
      return (
        <section class="pricing">
          <div class="container">
            <div class="pricing-grid">
              {(block.items ?? []).map((item: any) => (
                <div class:list={["pricing-card", { highlighted: item.highlighted }]}>
                  {item.highlighted && <div class="badge">おすすめ</div>}
                  <h3>{item.name}</h3>
                  <div class="price">
                    <span class="amount">{item.price}</span>
                    {item.period && <span class="period">{item.period}</span>}
                  </div>
                  <p class="plan-desc">{item.description}</p>
                  <ul class="feature-list">
                    {(item.features ?? []).map((f: string) => (
                      <li>
                        <span aria-hidden="true">✓</span> {f}
                      </li>
                    ))}
                  </ul>
                  {item.cta && (
                    <a href={item.cta.url} class:list={["plan-cta", { "plan-cta--primary": item.highlighted }]}>
                      {item.cta.label}
                    </a>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      );

    case "marketing.faq":
      return (
        <section class="faq">
          <div class="container">
            <div class="section-header">
              <h2>{block.headline}</h2>
            </div>
            <dl class="faq-list">
              {(block.items ?? []).map((item: any) => (
                <div class="faq-item">
                  <dt>{item.question}</dt>
                  <dd>{item.answer}</dd>
                </div>
              ))}
            </dl>
          </div>
        </section>
      );

    default:
      return null;
  }
})}

<style>
  /* ---- Hero ---- */
  .hero {
    padding: 6rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary {
    padding: 0.75rem 1.75rem;
    background: var(--color-primary);
    color: var(--color-primary-fg);
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.15s;
  }

  .cta-primary:hover { background: var(--color-primary-hover); }

  .cta-secondary {
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: border-color 0.15s;
  }

  .cta-secondary:hover { border-color: var(--color-text-muted); }

  /* ---- Section commons ---- */
  section { padding: 5rem 0; }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
  }

  .section-header p {
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  /* ---- Features ---- */
  .features { background: var(--color-bg-subtle); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) * 2);
    padding: 1.75rem;
  }

  .feature-icon {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .feature-card h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }

  .feature-card p { font-size: 0.9rem; color: var(--color-text-muted); margin: 0; }

  /* ---- Testimonials ---- */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) * 2);
    padding: 1.75rem;
    margin: 0;
  }

  .quote {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .testimonial-card footer {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.85rem;
  }

  .testimonial-card footer span { color: var(--color-text-muted); }

  /* ---- Pricing ---- */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) * 2);
    padding: 2rem;
    position: relative;
  }

  .pricing-card.highlighted {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: var(--color-primary-fg);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .pricing-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .price { margin-bottom: 0.75rem; }

  .amount { font-size: 2rem; font-weight: 700; }

  .period { font-size: 0.875rem; color: var(--color-text-muted); margin-left: 0.25rem; }

  .plan-desc { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 1.25rem; }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-list li {
    font-size: 0.875rem;
    display: flex;
    gap: 0.5rem;
  }

  .feature-list span { color: var(--color-primary); flex-shrink: 0; }

  .plan-cta {
    display: block;
    text-align: center;
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 600;
    transition: border-color 0.15s, background 0.15s;
  }

  .plan-cta:hover { border-color: var(--color-text-muted); }

  .plan-cta--primary {
    background: var(--color-primary);
    color: var(--color-primary-fg);
    border-color: var(--color-primary);
  }

  .plan-cta--primary:hover { background: var(--color-primary-hover); border-color: var(--color-primary-hover); }

  /* ---- FAQ ---- */
  .faq { background: var(--color-bg-subtle); }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .faq-item:first-child { border-top: 1px solid var(--color-border); }

  dt {
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  dd {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>
